	"tokenColors": [
		{
			"settings": {
				"foreground": "#101828"
			}
		},
		{
			"scope": [
				"keyword.operator.accessor",
				"meta.group.braces.round.function.arguments",
				"meta.template.expression",
				"markup.fenced_code meta.embedded.block"
			],
			"settings": {
				"foreground": "#101828"
			}
		},
		{
			"scope": "emphasis",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"strong",
				"markup.heading.markdown",
				"markup.bold.markdown"
			],
			"settings": {
				"fontStyle": "bold",
				"foreground": "#8250df"
			}
		},
		{
			"scope": [
				"markup.italic.markdown"
			],
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "meta.link.inline.markdown",
			"settings": {
				"fontStyle": "underline",
				"foreground": "#006b5e"
			}
		},
		{
			"scope": [
				"string",
				"markup.fenced_code",
				"markup.inline"
			],
			"settings": {
				"foreground": "#0a3069"
			}
		},
		{
			"scope": [
				"comment",
				"string.quoted.docstring.multi"
			],
			"settings": {
				"foreground": "#6e7781"
			}
		},
		{
			"scope": [
